{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "rewrites": [
    { "source": "/((?!assets/|sitemap\\.xml|robots\\.txt|ai-meta-ad-generator/).*)", "destination": "/index.html" }
  ]
}
